# BaconOS udev rules
# /etc/udev/rules.d/99-baconos.rules

# ════════════════════════════════════════════════════════════════════════════════
# USB Power Management — prevent ports from sleeping while devices are connected
# ════════════════════════════════════════════════════════════════════════════════
ACTION=="add", SUBSYSTEM=="usb", TEST=="power/control", ATTR{power/control}="on"

# ════════════════════════════════════════════════════════════════════════════════
# Storage — optimize I/O scheduler per device type
# ════════════════════════════════════════════════════════════════════════════════

# NVMe SSDs — use 'none' scheduler (hardware does its own queuing)
ACTION=="add|change", KERNEL=="nvme[0-9]*", ATTR{queue/scheduler}="none"

# SATA SSDs (detected by rotational=0) — use 'mq-deadline' for low latency
ACTION=="add|change", KERNEL=="sd[a-z]|sd[a-z][a-z]", \
    ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="mq-deadline"

# HDDs (rotational=1) — use 'bfq' for fair queuing
ACTION=="add|change", KERNEL=="sd[a-z]|sd[a-z][a-z]", \
    ATTR{queue/rotational}=="1", ATTR{queue/scheduler}="bfq"

# eMMC (internal flash) — use 'mq-deadline'
ACTION=="add|change", KERNEL=="mmcblk[0-9]", ATTR{queue/scheduler}="mq-deadline"

# ════════════════════════════════════════════════════════════════════════════════
# CPU — set governor to 'schedutil' for responsive scaling
# ════════════════════════════════════════════════════════════════════════════════
ACTION=="add", SUBSYSTEM=="cpu", KERNEL=="cpu[0-9]*", \
    TEST=="power/energy_perf_bias", ATTR{power/energy_perf_bias}="6"

# ════════════════════════════════════════════════════════════════════════════════
# Gaming controllers — grant user access without sudo
# ════════════════════════════════════════════════════════════════════════════════

# Xbox controllers
SUBSYSTEM=="usb", ATTRS{idVendor}=="045e", MODE="0666", TAG+="uaccess"

# PlayStation 4 DualShock
SUBSYSTEM=="usb", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="05c4", \
    MODE="0666", TAG+="uaccess"

# PlayStation 5 DualSense
SUBSYSTEM=="usb", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0ce6", \
    MODE="0666", TAG+="uaccess"

# Nintendo Switch Pro Controller
SUBSYSTEM=="usb", ATTRS{idVendor}=="057e", ATTRS{idProduct}=="2009", \
    MODE="0666", TAG+="uaccess"

# 8BitDo controllers
SUBSYSTEM=="usb", ATTRS{idVendor}=="2dc8", MODE="0666", TAG+="uaccess"

# ════════════════════════════════════════════════════════════════════════════════
# Backlight — allow user to control brightness without sudo
# ════════════════════════════════════════════════════════════════════════════════
ACTION=="add", SUBSYSTEM=="backlight", \
    RUN+="/bin/chgrp video /sys/class/backlight/%k/brightness", \
    RUN+="/bin/chmod g+w /sys/class/backlight/%k/brightness"

# ════════════════════════════════════════════════════════════════════════════════
# Android / ADB — developer mode USB access
# ════════════════════════════════════════════════════════════════════════════════
SUBSYSTEM=="usb", ATTRS{idVendor}=="18d1", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="usb", ATTRS{idVendor}=="04e8", MODE="0666", GROUP="plugdev"
SUBSYSTEM=="usb", ATTRS{idVendor}=="2717", MODE="0666", GROUP="plugdev"

# ════════════════════════════════════════════════════════════════════════════════
# Yubikey / FIDO2 — passwordless auth support
# ════════════════════════════════════════════════════════════════════════════════
ACTION=="add|change", SUBSYSTEM=="usb", \
    ATTRS{idVendor}=="1050", ATTRS{idProduct}=="0010|0110|0111|0114|0116|0401|0403|0405|0407|0410", \
    MODE="0660", GROUP="plugdev", TAG+="uaccess"

# ════════════════════════════════════════════════════════════════════════════════
# Printers — auto-add to print queue when plugged in
# ════════════════════════════════════════════════════════════════════════════════
ACTION=="add", SUBSYSTEM=="usb", ENV{ID_USB_INTERFACES}=="*:0701*", \
    RUN+="/usr/lib/cups/driver/usb-printers-udev"
