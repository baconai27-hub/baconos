# BaconOS system-wide dconf defaults
# /etc/dconf/db/baconos.d/00-defaults

[org/gnome/desktop/interface]
gtk-theme='BaconShell'
color-scheme='prefer-dark'
icon-theme='Papirus-Dark'
cursor-theme='Yaru'
font-name='Inter 11'
monospace-font-name='JetBrains Mono 12'
document-font-name='Inter 11'
accent-color='orange'
show-battery-percentage=true
clock-show-weekday=true
clock-show-date=true
clock-format='24h'
enable-hot-corners=false
locate-pointer=true

[org/gnome/desktop/background]
picture-options='zoom'
picture-uri='file:///usr/share/backgrounds/baconos/default-dark.jpg'
picture-uri-dark='file:///usr/share/backgrounds/baconos/default-dark.jpg'
primary-color='#0d0805'

[org/gnome/desktop/screensaver]
picture-options='zoom'
picture-uri='file:///usr/share/backgrounds/baconos/default-dark.jpg'
primary-color='#0d0805'

[org/gnome/desktop/wm/preferences]
button-layout='appmenu:minimize,maximize,close'
focus-mode='click'
num-workspaces=4
action-double-click-titlebar='toggle-maximize'

[org/gnome/desktop/wm/keybindings]
switch-applications=['<Super>Tab']
switch-windows=['<Alt>Tab']
close=['<Super>q','<Alt>F4']

[org/gnome/shell]
favorite-apps=['firefox.desktop','org.gnome.Nautilus.desktop','org.gnome.Terminal.desktop','kitty.desktop','code.desktop','org.gnome.SystemMonitor.desktop']
enabled-extensions=['user-theme@gnome-shell-extensions.gcampax.github.com','appindicatorsupport@rgcjonas.gmail.com','blur-my-shell@aunetx']

[org/gnome/shell/extensions/user-theme]
name='BaconShell'

[org/gnome/shell/extensions/blur-my-shell]
blur-overview=true
blur-panel=true
panel-blur-amount=uint32 3
overview-blur-amount=uint32 5

[org/gnome/mutter]
dynamic-workspaces=false
workspaces-only-on-primary=true
center-new-windows=true
experimental-features=['scale-monitor-framebuffer','kms-modifiers','rt-scheduler']

[org/gnome/settings-daemon/plugins/power]
sleep-inactive-ac-timeout=3600
sleep-inactive-battery-timeout=1200
power-button-action='interactive'
ambient-enabled=true

[org/gnome/nautilus/preferences]
default-folder-viewer='list-view'
show-hidden-files=false
sort-directories-first=true

[org/gnome/nautilus/list-view]
default-zoom-level='small'
use-tree-view=true

[org/gnome/terminal/legacy]
theme-variant='dark'

[org/gtk/settings/file-chooser]
show-hidden=false
sort-directories-first=true

[org/gnome/system-monitor]
show-whose-processes='user'
current-tab='resources'

[org/gnome/gedit/preferences/editor]
scheme='oblivion'
use-default-font=false
editor-font='JetBrains Mono 12'
display-line-numbers=true
highlight-current-line=true
auto-indent=true
insert-spaces-instead-of-tabs=true
tabs-size=uint32 4
