# BaconOS .gitignore

# ── Build artifacts ────────────────────────────────────────────────────────────
build_workspace/
output/
*.iso
*.md5
*.sha256

# ── Secrets / credentials ──────────────────────────────────────────────────────
*.pem
*.key
*.crt
id_rsa
id_ed25519
.env
.env.*
secrets/

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
*~
*.swp
*.swo
.#*
\#*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
.venv/
venv/
.pytest_cache/

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
